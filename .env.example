# Google / Gmail
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GMAIL_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-receipts
GMAIL_USER_EMAIL=you@gmail.com

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Xero
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=https://your-zeabur-url.zeabur.app/xero/callback
XERO_DEFAULT_ACCOUNT_CODE=400

# App
APP_BASE_URL=https://your-zeabur-url.zeabur.app
DATABASE_PATH=data/app.db
